import { NextResponse } from 'next/server'
import { redis } from '@/lib/redis'
import { calculateBias, getBiasLabel } from '@/lib/engines/biasEngine'
import { fetchYahooPrices } from '@/lib/api/yahoo'
import { CACHE_TTL } from '@/lib/constants'

export const dynamic = 'force-dynamic'
export const maxDuration = 30

export async function POST() {
  try {
    const cacheKey = 'gold_report'
    const cached = await redis.get(cacheKey)
    if (cached) return NextResponse.json(cached)

    const [prices, bias] = await Promise.all([
      fetchYahooPrices(),
      calculateBias(),
    ])

    const gold = prices.XAUUSD
    const swingLabel = getBiasLabel(bias.swing.score)
    const dayLabel   = getBiasLabel(bias.day.score)

    const prompt = `
Tu es un analyste gold senior spécialisé XAU/USD. Réponds uniquement en français.

DONNÉES ACTUELLES :
- Prix XAU/USD : ${gold?.price} USD (${gold?.changePct >= 0 ? '+' : ''}${gold?.changePct?.toFixed(2)}%)
- High : ${gold?.high} | Low : ${gold?.low} | Open : ${gold?.open}
- Bias Swing : ${swingLabel} (score: ${bias.swing.score.toFixed(2)})
- Bias Day : ${dayLabel} (score: ${bias.day.score.toFixed(2)})
- DXY : ${prices.DXY?.price} (${prices.DXY?.changePct?.toFixed(2)}%)
- US10Y : ${prices.US10Y?.price}%
- XAG/USD : ${prices.XAGUSD?.price} (${prices.XAGUSD?.changePct?.toFixed(2)}%)
- VIX : ${prices.VIX?.price}
- SP500 : ${prices.SP500?.changePct?.toFixed(2)}%

Génère un rapport structuré avec exactement ces 7 sections :

## SITUATION ACTUELLE
[2-3 phrases sur le contexte actuel du gold]

## CATALYSEURS
[Ce qui fait bouger le prix maintenant]

## CORRÉLATIONS
- DXY : [impact sur gold]
- US10Y : [impact sur gold]
- XAG/USD : [corrélation]
- VIX : [sentiment]
- SP500 : [risk on/off]

## BIAIS DIRECTIONNEL
- Swing : [explication]
- Day : [explication]
- Conclusion : [synthèse]

## NIVEAUX CLÉS
- Support : [niveau]
- Résistance : [niveau]
- Commentaire : [pourquoi]

## RISQUES
- [Risque 1]
- [Risque 2]

## CONCLUSION
[Recommandation claire : opportunité / attendre / éviter]
`

    let report: string

    try {
      const geminiRes = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${process.env.GEMINI_API_KEY}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: { temperature: 0.3, maxOutputTokens: 2000 },
          }),
        }
      )

      if (!geminiRes.ok) throw new Error(`Gemini error: ${geminiRes.status}`)
      const geminiData = await geminiRes.json()
      report = geminiData.candidates?.[0]?.content?.parts?.[0]?.text ?? ''

    } catch (geminiError) {
      console.warn('[REPORT] Gemini failed, using Groq:', geminiError)

      const groqRes = await fetch('https://api.groq.com/openai/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${process.env.GROQ_API_KEY}`,
        },
        body: JSON.stringify({
          model: 'llama-3.3-70b-versatile',
          messages: [{ role: 'user', content: prompt }],
          temperature: 0.3,
          max_tokens: 2000,
        }),
      })

      const groqData = await groqRes.json()
      report = groqData.choices?.[0]?.message?.content ?? 'Rapport indisponible'
    }

    console.log('[REPORT] Généré ✅')
    await redis.set(cacheKey, { report }, { ex: CACHE_TTL.REPORT })
    return NextResponse.json({ report })

  } catch (error) {
    console.error('[REPORT] Error:', error)
    return NextResponse.json(
      { error: 'Failed to generate report' },
      { status: 500 }
    )
  }
}